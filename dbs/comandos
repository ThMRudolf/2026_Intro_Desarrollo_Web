CREATE TABLE Persona (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    nombre TEXT NOT NULL,
    fecha_nacimiento TEXT,
    total_hermanos INTEGER,
    estado TEXT,
    musica_favorita TEXT,
    soltero BOOLEAN
);


